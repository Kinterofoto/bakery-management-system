# MQTT (bridge connects to mosquitto container by service name)
MQTT_HOST=mosquitto
MQTT_PORT=1883

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=your-influxdb-admin-token
INFLUXDB_ORG=pastrychef
INFLUXDB_BUCKET=sensors
INFLUXDB_RETENTION=365d
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=your-secure-password
